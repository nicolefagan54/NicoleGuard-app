<Window x:Class="NicoleGuard.UI.Views.ProcessMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NicoleGuard Process Monitor" Height="600" Width="1000"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Active System Processes &amp; Signatures" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource AccentBrush}"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnRefreshOps" Content="Refresh Processes" Width="150" Margin="0,0,10,0" Click="BtnRefreshOps_Click"/>
            <Button x:Name="BtnRefreshNet" Content="Refresh Network" Width="150" Click="BtnRefreshNet_Click"/>
        </StackPanel>

        <TabControl Grid.Row="2" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}">
            <TabItem Header="Processes" Foreground="{DynamicResource ForegroundBrush}" Background="{DynamicResource BackgroundBrush}">
                <DataGrid x:Name="GridProcesses" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
                          RowBackground="{DynamicResource BackgroundBrush}" AlternatingRowBackground="{DynamicResource SurfaceBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="60"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding ProcessName}" Width="150"/>
                        <DataGridTextColumn Header="Signature Status" Binding="{Binding SignatureStatus}" Width="150"/>
                        <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="150"/>
                        <DataGridTextColumn Header="Memory (MB)" Binding="{Binding MemoryUsageMB}" Width="100"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Network Connections" Foreground="{DynamicResource ForegroundBrush}" Background="{DynamicResource BackgroundBrush}">
                <DataGrid x:Name="GridNetwork" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
                          RowBackground="{DynamicResource BackgroundBrush}" AlternatingRowBackground="{DynamicResource SurfaceBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="60"/>
                        <DataGridTextColumn Header="Local Address" Binding="{Binding LocalAddress}" Width="150"/>
                        <DataGridTextColumn Header="Foreign Address" Binding="{Binding RemoteAddress}" Width="150"/>
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="60"/>
                        <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
