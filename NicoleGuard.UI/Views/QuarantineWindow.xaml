<Window x:Class="NicoleGuard.UI.Views.QuarantineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quarantine" Height="350" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GridQuarantine" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Original Path" Binding="{Binding OriginalPath}" Width="2*"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                <DataGridTextColumn Header="Date" Binding="{Binding QuarantinedAt}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Restore" Width="80" Margin="0,0,10,0" Click="Restore_Click"/>
            <Button Content="Delete" Width="80" Click="Delete_Click"/>
        </StackPanel>
    </Grid>
</Window>
