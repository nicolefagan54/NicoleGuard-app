<Window x:Class="NicoleGuard.UI.Views.SandboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Antigravity Sandbox execution Container" Height="400" Width="600"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SANDBOX ANALYZER" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AccentColorBrush}" Margin="0,0,0,10" Grid.Row="0"/>
        
        <TextBlock x:Name="TxtStatus" Text="Ready to safely detonate suspicious file." 
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10" Grid.Row="1"/>

        <Border Grid.Row="2" BorderBrush="{DynamicResource AccentColorBrush}" BorderThickness="1" Background="#1A1A1A" Margin="0,0,0,10">
            <ScrollViewer>
                <TextBlock x:Name="TxtOutput" Foreground="#00FF00" FontFamily="Consolas" TextWrapping="Wrap" Padding="5"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnRun" Content="Detonate in Sandbox" Width="150" Height="30" Margin="0,0,10,0"
                    Background="{DynamicResource AccentColorBrush}" Foreground="White" BorderThickness="0"
                    Click="BtnRun_Click"/>
            <Button x:Name="BtnClose" Content="Close" Width="100" Height="30" 
                    Background="#555555" Foreground="White" BorderThickness="0"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
