<Window x:Class="NicoleGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NicoleGuard - Antigravity Edition" Height="450" Width="800"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnShieldScan" Content="🛡️ Shield Scan" Width="100" Margin="0,0,10,0" Click="BtnShieldScan_Click" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="BtnChooseFolder" Content="Choose Folder" Width="120" Margin="0,0,10,0" Click="BtnChooseFolder_Click"/>
            <Button x:Name="BtnScan" Content="Scan" Width="80" Margin="0,0,10,0" Click="BtnScan_Click"/>
            <Button x:Name="BtnUpdateSignatures" Content="⬇️ Update Signatures" Width="130" Margin="0,0,10,0" Click="BtnUpdateSignatures_Click"/>
            <Button x:Name="BtnQuarantineWindow" Content="Quarantine" Width="100" Margin="0,0,10,0" Click="BtnQuarantineWindow_Click"/>
            <ComboBox x:Name="CboTheme" Width="90" Margin="0,0,10,0" SelectionChanged="CboTheme_SelectionChanged">
                <ComboBoxItem Content="DarkTheme"/>
                <ComboBoxItem Content="LightTheme"/>
            </ComboBox>
            <CheckBox x:Name="ChkActiveProtection" Content="Active Shield" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource ForegroundBrush}" Checked="ChkActiveProtection_CheckedChanged" Unchecked="ChkActiveProtection_CheckedChanged"/>
            <Button x:Name="BtnScanStartup" Content="Scan Startup" Width="100" Margin="0,0,10,0" Click="BtnScanStartup_Click"/>

            <Button x:Name="BtnProcMon" Content="Task Mgr" Width="80" Margin="0,0,10,0" Click="BtnProcMon_Click"/>
            <Button x:Name="BtnSettings" Content="Settings" Width="80" Margin="0,0,10,0" Click="BtnSettings_Click"/>
            <Button x:Name="BtnExport" Content="Export" Width="80" Margin="0,0,10,0" Click="BtnExport_Click"/>
            
            <Grid Width="20" Height="20" Margin="0,0,10,0" ToolTip="Gravity Scan Indicator">
                <Ellipse x:Name="PulseRing" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" Opacity="0" Visibility="Hidden"/>
                <Ellipse Fill="{DynamicResource AccentBrush}" Width="10" Height="10" />
            </Grid>

            <Button x:Name="BtnFixThreats" Content="Fix Threats" Width="100" Margin="0,0,10,0" Click="BtnFixThreats_Click" Visibility="Collapsed" Background="#FF3333" Foreground="White"/>

            <TextBlock x:Name="TxtStatus" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
        </StackPanel>

        <DataGrid x:Name="GridResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="{DynamicResource BackgroundBrush}" 
                  Foreground="{DynamicResource ForegroundBrush}"
                  RowBackground="{DynamicResource BackgroundBrush}"
                  AlternatingRowBackground="#33000000"
                  HorizontalGridLinesBrush="{DynamicResource AccentBrush}"
                  VerticalGridLinesBrush="{DynamicResource AccentBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File" Binding="{Binding FilePath}" Width="*"/>
                <DataGridTextColumn Header="Hash" Binding="{Binding Hash}" Width="*"/>
                <DataGridCheckBoxColumn Header="Malicious" Binding="{Binding IsMalicious}"/>
                <DataGridTextColumn Header="Gravity Score" Binding="{Binding ThreatGravityScore}"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding DetectionReason}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnRunSandbox" Content="Run in Sandbox" Width="130" Margin="0,0,10,0" Background="#FFAA00" Foreground="Black" Click="BtnRunSandbox_Click" />
            <Button x:Name="BtnQuarantineSelected" Content="Quarantine Selected" Width="150" Click="BtnQuarantineSelected_Click"/>
        </StackPanel>
    </Grid>
</Window>
