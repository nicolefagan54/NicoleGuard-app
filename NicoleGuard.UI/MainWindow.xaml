<Window x:Class="NicoleGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NicoleGuard" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnChooseFolder" Content="Choose Folder" Width="120" Margin="0,0,10,0" Click="BtnChooseFolder_Click"/>
            <Button x:Name="BtnScan" Content="Scan" Width="80" Margin="0,0,10,0" Click="BtnScan_Click"/>
            <Button x:Name="BtnQuarantineWindow" Content="Quarantine" Width="100" Click="BtnQuarantineWindow_Click"/>
            <TextBlock x:Name="TxtStatus" Margin="20,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid x:Name="GridResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File" Binding="{Binding FilePath}" Width="*"/>
                <DataGridTextColumn Header="Hash" Binding="{Binding Hash}" Width="2*"/>
                <DataGridTextColumn Header="Malicious" Binding="{Binding IsMalicious}" Width="80"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding DetectionReason}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnQuarantineSelected" Content="Quarantine Selected" Width="150" Click="BtnQuarantineSelected_Click"/>
        </StackPanel>
    </Grid>
</Window>
