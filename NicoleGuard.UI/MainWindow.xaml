<Window x:Class="NicoleGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NicoleGuard.UI"
        xmlns:viewmodels="clr-namespace:NicoleGuard.UI.ViewModels"
        mc:Ignorable="d"
        Title="NicoleGuard Security Scanner" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Controls -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="15" Margin="0,0,0,10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Target Directory:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Padding="5"/>
                
                <Button Grid.Column="2" Content="Start Scan" Command="{Binding StartScanCommand}" Margin="10,0,0,0" Padding="15,5" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                <Button Grid.Column="3" Content="Stop" Command="{Binding StopScanCommand}" Margin="10,0,0,0" Padding="15,5" Background="#F44336" Foreground="White"/>
            </Grid>
        </Border>

        <!-- Stats Overview -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="#E3F2FD" Padding="15" Margin="0,0,5,0" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Files Scanned" FontSize="14" Foreground="#555"/>
                    <TextBlock Text="{Binding TotalFilesScanned}" FontSize="24" FontWeight="Bold" Foreground="#1565C0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#FFEBEE" Padding="15" Margin="5,0,0,0" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Threats Found" FontSize="14" Foreground="#555"/>
                    <TextBlock Text="{Binding TotalThreatsFound}" FontSize="24" FontWeight="Bold" Foreground="#C62828"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tab Control -->
        <TabControl Grid.Row="2">
            
            <!-- Scan Results Tab -->
            <TabItem Header="Scan Results">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" ItemsSource="{Binding ScanResults}" AutoGenerateColumns="False" 
                              SelectedItem="{Binding SelectedThreat}" IsReadOnly="True" Margin="0,10,0,10" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Threat Name" Binding="{Binding ThreatName}" Width="150" />
                            <DataGridTextColumn Header="Type" Binding="{Binding ThreatType}" Width="100" />
                            <DataGridTextColumn Header="File Path" Binding="{Binding FilePath}" Width="*" />
                            <DataGridCheckBoxColumn Header="Quarantined" Binding="{Binding IsQuarantined}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="1" Content="Quarantine Selected Threat" Command="{Binding QuarantineSelectedCommand}" 
                            HorizontalAlignment="Right" Padding="15,5" Background="#FF9800" Foreground="White"/>
                </Grid>
            </TabItem>

            <!-- Quarantine Tab -->
            <TabItem Header="Quarantine Manager">
                <DataGrid ItemsSource="{Binding QuarantinedFiles}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,10,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Threat Name" Binding="{Binding ThreatName}" Width="150" />
                        <DataGridTextColumn Header="Quarantined At" Binding="{Binding QuarantinedAt}" Width="150" />
                        <DataGridTextColumn Header="Original Path" Binding="{Binding OriginalPath}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0" Background="#EEE">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar IsIndeterminate="{Binding IsScanning}" Width="150" Height="15" />
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
